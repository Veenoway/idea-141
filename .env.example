# Reown / WalletConnect — get a free project id at https://dashboard.reown.com
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Public app URL (used in wallet connect metadata)
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# Perpl API (default: mainnet)
PERPL_API_URL=https://app.perpl.xyz/api

# Testnet
# PERPL_API_URL=https://testnet.perpl.xyz/api

# Monad mainnet contract deploy (server-side only — never commit real keys)
# One line only — do NOT add a second empty DEPLOYER_PRIVATE_KEY= below
DEPLOYER_PRIVATE_KEY=

# Optional override for frontend if deployed.ts is empty
NEXT_PUBLIC_BACKTEST_REGISTRY_ADDRESS=

# Monad RPC (optional)
MONAD_RPC_URL=https://rpc.monad.xyz
MONAD_CHAIN_ID=143
